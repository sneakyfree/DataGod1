  "state_level_apis": {
    "secretary_of_state": {
      "url": "https://dos.myflorida.com/sunbiz/api",
      "data_types": ["corporations", "llcs", "partnerships", "fictitious_names"]
    },
    "courts": {
      "url": "https://www.flcourts.org/api",
      "data_types": ["case_search", "opinions", "filings"]
    },
    "bar_association": {
      "url": "https://www.floridabar.org/api",
      "data_types": ["attorney_lookup", "disciplinary_records"]
    },
    "professional_licensing": {
      "url": "https://www.myfloridalicense.com/api",
      "data_types": ["licenses", "violations"]
    },
    "dbpr": {
      "url": "https://www.myfloridalicense.com/dbpr/api",
      "data_types": ["business_licenses", "professional_licenses", "complaints"]
    }
  },
  "data_sources": {
    "property": {
      "type": "api",
      "url": "/property/search",
      "fields": ["owner_name", "property_address", "parcel_id", "just_value", "assessed_value", "taxable_value"]
    },
    "deed": {
      "type": "api",
      "url": "/deed/search",
      "fields": ["grantor", "grantee", "document_type", "record_date", "consideration", "official_records_book"]
    },
    "court": {
      "type": "api",
      "url": "/case/search",
      "fields": ["case_number", "case_type", "parties", "filing_date", "status", "division"]
    },
    "business": {
      "type": "api",
      "url": "/business/search",
      "fields": ["entity_name", "document_number", "status", "filing_date", "registered_agent"]
    }
  },
  "notes": "Florida has excellent public records access under the Sunshine Law. Property Appraisers handle property records. Clerks handle court records and recording."
}
