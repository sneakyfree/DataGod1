  "state_level_apis": {
    "secretary_of_state": {
      "url": "https://businesssearch.sos.ca.gov/api",
      "data_types": ["corporations", "llcs", "partnerships", "trademarks"]
    },
    "courts": {
      "url": "https://www.courts.ca.gov/api",
      "data_types": ["case_search", "opinions", "filings"]
    },
    "bar_association": {
      "url": "https://www.calbar.ca.gov/api",
      "data_types": ["attorney_lookup", "disciplinary_records"]
    },
    "professional_licensing": {
      "url": "https://www.dca.ca.gov/api",
      "data_types": ["licenses", "disciplinary_actions"]
    },
    "contractor_licensing": {
      "url": "https://www.cslb.ca.gov/api",
      "data_types": ["contractor_licenses", "violations"]
    }
  },
  "data_sources": {
    "property": {
      "type": "api",
      "url": "/property/search",
      "fields": ["owner_name", "property_address", "apn", "assessed_value", "market_value", "tax_amount"]
    },
    "deed": {
      "type": "api",
      "url": "/deed/search",
      "fields": ["grantor", "grantee", "document_type", "record_date", "consideration", "document_number"]
    },
    "court": {
      "type": "api",
      "url": "/case/search",
      "fields": ["case_number", "case_type", "parties", "filing_date", "status"]
    },
    "business": {
      "type": "api",
      "url": "/business/search",
      "fields": ["entity_name", "entity_number", "status", "formation_date", "agent"]
    }
  },
  "notes": "California has the largest population and most comprehensive public records access. Most major counties have API access. Secretary of State provides business entity search."
}
