  "state_level_apis": {
    "secretary_of_state": {
      "url": "https://appext20.dos.ny.gov/corp_public/api",
      "data_types": ["corporations", "llcs", "partnerships", "assumed_names"]
    },
    "courts": {
      "url": "https://iapps.courts.state.ny.us/api",
      "data_types": ["ecourts", "webcrims", "webcivilsupreme"]
    },
    "bar_association": {
      "url": "https://www.nysba.org/api",
      "data_types": ["attorney_lookup"]
    },
    "attorney_registration": {
      "url": "https://iapps.courts.state.ny.us/attorney/api",
      "data_types": ["attorney_search", "disciplinary_history"]
    },
    "professional_licensing": {
      "url": "https://www.op.nysed.gov/api",
      "data_types": ["licenses", "disciplinary_actions"]
    },
    "acris": {
      "url": "https://a836-acris.nyc.gov/api",
      "data_types": ["property_records", "deeds", "mortgages"],
      "coverage": "NYC only"
    }
  },
  "data_sources": {
    "property": {
      "type": "api",
      "url": "/property/search",
      "fields": ["owner_name", "property_address", "block", "lot", "assessed_value", "market_value"]
    },
    "deed": {
      "type": "api",
      "url": "/deed/search",
      "fields": ["grantor", "grantee", "document_type", "record_date", "consideration", "crfn"]
    },
    "court": {
      "type": "api",
      "url": "/case/search",
      "fields": ["index_number", "case_type", "parties", "filing_date", "status"]
    },
    "business": {
      "type": "api",
      "url": "/business/search",
      "fields": ["entity_name", "dos_id", "status", "formation_date", "registered_agent"]
    }
  },
  "notes": "New York has 62 counties including NYC's 5 boroughs. NYC uses ACRIS for property records. eCourts provides statewide case access."
}
