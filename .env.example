# DataGod Environment Configuration
# Copy this file to .env and update the values
#
# QUICK START:
#   cp .env.example .env
#   docker-compose up -d
#
# For production, generate secure keys:
#   openssl rand -hex 32

# =============================================================================
# DOCKER CONFIGURATION (used by docker-compose.yml)
# =============================================================================

# PostgreSQL Docker container settings
POSTGRES_USER=datagod
POSTGRES_PASSWORD=datagod_dev_password
POSTGRES_DB=datagod
DB_PORT=5432

# Redis Docker container settings
REDIS_PASSWORD=redis_dev_password
REDIS_PORT=6379

# Service ports
API_PORT=8000
FRONTEND_PORT=3000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection (for Docker deployment)
DATABASE_URL=postgresql://datagod:datagod_dev_password@db:5432/datagod

# For local development without Docker, use SQLite:
# DATABASE_URL=sqlite:///db/datagod.db

# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# API CONFIGURATION
# =============================================================================

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_DEBUG=false

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# IMPORTANT: Change these in production!
SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_SECRET_KEY=change-this-to-another-secure-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# REDIS CONFIGURATION (for caching)
# =============================================================================

REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================

# Florida Property Appraiser API
FLORIDA_PROPERTY_APPRAISER_API_KEY=

# California Secretary of State API
CALIFORNIA_SOS_API_KEY=

# Add other API keys as needed
# TEXAS_API_KEY=
# NEW_YORK_API_KEY=

# =============================================================================
# SCRAPING CONFIGURATION
# =============================================================================

SCRAPER_RATE_LIMIT=1.0
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_CONCURRENT_REQUESTS=5
SCRAPER_USE_PROXIES=false

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/datagod.log

# =============================================================================
# EMAIL CONFIGURATION (for notifications)
# =============================================================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@datagod.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================

ENABLE_ADVANCED_SEARCH=true
ENABLE_DATA_EXPORT=true
ENABLE_REAL_TIME_UPDATES=false
ENABLE_USER_MANAGEMENT=false
ENABLE_SUBSCRIPTION_SYSTEM=false

# =============================================================================
# ENVIRONMENT
# =============================================================================

ENVIRONMENT=development
DEBUG=true

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# =============================================================================
# RATE LIMITING
# =============================================================================

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# CACHE SETTINGS
# =============================================================================

CACHE_ENABLED=true
CACHE_BACKEND=redis
CACHE_DEFAULT_TTL=300

# =============================================================================
# PAGINATION
# =============================================================================

DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=1000

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# =============================================================================
# CELERY CONFIGURATION (for background tasks)
# =============================================================================

CELERY_BROKER_URL=redis://:redis_dev_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_dev_password@redis:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# =============================================================================
# STRIPE CONFIGURATION (for payments - optional)
# =============================================================================

# Test keys (use sk_test_ and pk_test_ for development)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe dashboard
# STRIPE_PRICE_ID_BASIC=price_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_ENTERPRISE=price_...
